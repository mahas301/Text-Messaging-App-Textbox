<!DOCTYPE html>
<html lang="en" data-theme="<%= theme %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TextBox – <%= conversation.display_name || conversation.contact_name || conversation.contact_number %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="app-layout">
  <%- include('partials/sidebar', { folder: conversation.status, phones, counts, activePhoneId, theme }) %>

  <main class="main-area thread-main">

    <!-- Thread Header -->
    <header class="thread-header">
      <a href="/<%= conversation.status === 'inbox' ? 'inbox' : conversation.status %>" class="back-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:15px;height:15px"><polyline points="15,18 9,12 15,6"/></svg>
        Back
      </a>

      <a href="/profile/<%= encodeURIComponent(conversation.contact_number) %>" class="thread-contact-link">
        <div class="thread-av">
          <%= (conversation.display_name || conversation.contact_name || conversation.contact_number).charAt(0).toUpperCase() %>
        </div>
        <div>
          <div class="thread-name">
            <%= conversation.display_name || conversation.contact_name || conversation.contact_number %>
            <span class="online-pill hidden" id="contactOnlinePill">● online</span>
          </div>
          <div class="thread-num" id="contactSubline">
            <%= conversation.contact_number %>
            <span id="typingIndicator" class="typing-text hidden">typing…</span>
          </div>
        </div>
      </a>

      <% if (conversation.subject) { %>
      <div class="thread-subj">Re: <%= conversation.subject %></div>
      <% } %>

      <div class="thread-acts">
        <!-- Save Contact button (show if not yet saved) -->
        <% if (!savedContact) { %>
        <button class="btn btn-ghost btn-sm" onclick="openSaveContact()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          Save Contact
        </button>
        <% } else { %>
        <a href="/profile/<%= encodeURIComponent(conversation.contact_number) %>" class="btn btn-ghost btn-sm">👤 Profile</a>
        <% } %>

        <a href="/conversation/<%= conversation.id %>/deleted" class="btn btn-ghost btn-sm">🗑 Deleted</a>

        <% if (conversation.status !== 'spam') { %>
        <form method="POST" action="/conversation/<%= conversation.id %>/move">
          <input type="hidden" name="destination" value="spam">
          <button class="btn btn-ghost btn-sm">Spam</button>
        </form>
        <% } %>
        <% if (conversation.status !== 'trash') { %>
        <form method="POST" action="/conversation/<%= conversation.id %>/move">
          <input type="hidden" name="destination" value="trash">
          <button class="btn btn-ghost btn-sm">Delete</button>
        </form>
        <% } else { %>
        <form method="POST" action="/conversation/<%= conversation.id %>/move">
          <input type="hidden" name="destination" value="inbox">
          <button class="btn btn-primary btn-sm">Restore</button>
        </form>
        <% } %>

        <button class="theme-toggle" id="themeToggle" title="Toggle theme">
          <span class="theme-sun">☀️</span><span class="theme-moon">🌙</span>
        </button>
      </div>
    </header>

    <!-- Messages scroll area -->
    <div class="messages-scroll" id="msgScroll">
      <% if (messages.length === 0) { %>
      <div class="empty-state"><p class="empty-title">No messages yet. Say hello!</p></div>
      <% } %>

      <% let lastDate = null; %>
      <% messages.forEach(msg => { %>
        <%
          const msgDate = new Date(msg.created_at).toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'});
          const showDate = msgDate !== lastDate;
          lastDate = msgDate;
        %>
        <% if (showDate) { %>
        <div class="date-divider"><span><%= msgDate %></span></div>
        <% } %>

        <div class="msg-row <%= msg.direction %>" data-id="<%= msg.id %>">
          <div class="bubble">
            <p class="bubble-text"><%= msg.body %></p>
            <div class="bubble-meta">
              <span class="bubble-time">
                <%= new Date(msg.created_at).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}) %>
              </span>
              <% if (msg.direction === 'outbound') { %>
              <span class="bubble-status">✓✓</span>
              <form method="POST" action="/message/<%= msg.id %>/delete" class="inline-form">
                <button type="submit" class="del-msg-btn" title="Delete message">✕</button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
      <div id="msgEnd"></div>
    </div>

    <!-- Reply box -->
    <% if (conversation.status !== 'trash') { %>
    <div class="reply-area">
      <form method="POST" action="/conversation/<%= conversation.id %>/reply" id="replyForm">
        <div class="reply-box">
          <div class="reply-top">
            <textarea class="reply-input" name="body" id="replyBody"
              placeholder="Type a message… (Ctrl+Enter to send)"
              maxlength="500" rows="2" required></textarea>
          </div>
          <div class="reply-bot">
            <div class="reply-left">
              <button type="button" class="emoji-toggle" onclick="toggleEmoji()" title="Emoji">😊</button>
              <span class="char-counter" id="replyCounter">0 / 500</span>
            </div>
            <button type="submit" class="btn btn-primary send-btn" id="sendBtn">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:14px;height:14px"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22,2 15,22 11,13 2,9"/></svg>
              Send
            </button>
          </div>
        </div>
        <div class="emoji-strip hidden" id="replyEmojis"></div>
      </form>
    </div>
    <% } else { %>
    <div class="trash-bar">
      This conversation is in Trash.
      <form method="POST" action="/conversation/<%= conversation.id %>/move" style="display:inline">
        <input type="hidden" name="destination" value="inbox">
        <button class="btn btn-primary btn-sm">Restore to Inbox</button>
      </form>
    </div>
    <% } %>

  </main>

  <!-- Save Contact Modal -->
  <div class="modal-mask" id="saveContactMask">
    <div class="modal">
      <div class="modal-hd">
        <span class="modal-title">Save Contact</span>
        <button class="modal-close" onclick="closeSaveContact()">✕</button>
      </div>
      <form method="POST" action="/contacts/save" class="modal-body">
        <input type="hidden" name="redirect_to" value="/conversation/<%= conversation.id %>">
        <div class="field">
          <label class="field-label">Phone Number</label>
          <input class="field-input" type="text" value="<%= conversation.contact_number %>" name="phone_number" readonly>
        </div>
        <div class="field">
          <label class="field-label">Contact Name</label>
          <input class="field-input" type="text" name="name"
            value="<%= conversation.display_name !== conversation.contact_number ? (conversation.display_name || '') : '' %>"
            placeholder="Enter a name" required autofocus>
        </div>
        <div class="modal-ft">
          <button type="button" class="btn btn-ghost" onclick="closeSaveContact()">Cancel</button>
          <button type="submit" class="btn btn-primary">Save Contact</button>
        </div>
      </form>
    </div>
  </div>

  <div class="toast-wrap" id="toastWrap"></div>

  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/app.js"></script>
  <script>
    window.TB = {
      myPhone:        '<%= activePhone || "" %>',
      contactPhone:   '<%= conversation.contact_number %>',
      conversationId: <%= conversation.id %>,
      folder:         '<%= conversation.status %>'
    };
    initSocket();

    const ms = document.getElementById('msgScroll');
    if (ms) ms.scrollTop = ms.scrollHeight;

    function openSaveContact()  { document.getElementById('saveContactMask').classList.add('open'); }
    function closeSaveContact() { document.getElementById('saveContactMask').classList.remove('open'); }
    document.addEventListener('click', e => { if (e.target === document.getElementById('saveContactMask')) closeSaveContact(); });
  </script>
</body>
</html>
